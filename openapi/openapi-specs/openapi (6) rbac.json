      "delete": {
        "tags": [
          "Trouble Shooting"
        ],
        "summary": "deleteExecutions",
        "description": "This API will delete the execution entries older than specific number of days",
        "operationId": "deleteExecutions",
        "parameters": [
          {
            "name": "days_older_by",
            "in": "query",
            "description": "Deletes execution entries older than specified number of days",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {}
          },
          "202": {
            "description": "ACCEPTED",
