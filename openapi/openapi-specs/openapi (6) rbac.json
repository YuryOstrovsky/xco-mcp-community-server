{
  "openapi": "3.0.3",
  "info": {
    "title": "RBAC Service",
    "description": "This is the spec that defines the API provided by the application to validate authorization for the passed role",
    "contact": {
      "name": "Extreme Networks",
      "url": "http://www.extremenetworks.com",
      "email": "support@extremenetworks.com"
    },
    "license": {
      "name": "Apache license",
      "url": "http://www.extremenetworks.com"
    },
    "version": "3.8.0"
  },
  "servers": [
    {
      "url": "http://gorbac-service:80/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/rbac/isauthorized": {
      "get": {
        "tags": [
          "RBAC"
        ],
        "summary": "Validate authorization",
        "description": "Validates authorization for the role",
        "operationId": "CheckPermissions",
        "parameters": [
          {
            "name": "roles",
            "in": "query",
            "description": "One or more role names passed from the northbound API",
            "required": true,
            "style": "form",
            "explode": false,
            "schema": {
              "minItems": 1,
              "uniqueItems": true,
              "type": "array",
              "items": {
                "type": "string"
              },
              "x-exportParamName": "Roles"
            },
            "x-exportParamName": "Roles"
          },
          {
            "name": "method",
            "in": "query",
            "description": "Method passed from the northbound API",
            "required": true,
            "schema": {
              "type": "string",
              "x-exportParamName": "Method"
            },
            "x-exportParamName": "Method"
          },
          {
            "name": "path",
            "in": "query",
            "description": "Path passed from the northbound API",
            "required": true,
            "schema": {
              "type": "string",
              "x-exportParamName": "Path"
            },
            "x-exportParamName": "Path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {}
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "403": {
            "description": "No permission to access the resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
