  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ExecutionsResponse": {
        "title": "RBAC Data",
        "type": "object",
        "properties": {
          "items": {
            "uniqueItems": true,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExecutionResponse"
            }
          }
        },
        "example": {
          "items": [
            {
              "start_time": "2000-01-23T04:56:07.000+00:00",
              "end_time": "2000-01-23T04:56:07.000+00:00",
              "id": "id",
              "command": "configure add",
              "status": "configure add"
            },
            {
              "start_time": "2000-01-23T04:56:07.000+00:00",
              "end_time": "2000-01-23T04:56:07.000+00:00",
              "id": "id",
              "command": "configure add",
              "status": "configure add"
            }
          ]
        }
      },
      "ExecutionResponse": {
        "title": "Single execution response",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the operation"
          },
          "command": {
            "type": "string",
            "description": "Command that was executed",
            "example": "configure add"
          },
          "status": {
            "type": "string",
            "description": "Command that was executed",
            "example": "configure add"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "username": {
            "type": "string",
            "description": "Name of the user who executed the command"
          }
        },
        "example": {
          "start_time": "2000-01-23T04:56:07.000+00:00",
          "end_time": "2000-01-23T04:56:07.000+00:00",
          "id": "id",
          "command": "configure add",
          "status": "configure add"
        }
      },
      "DetailedExecutionResponse": {
        "title": "Detailed output of single execution",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the operation"
          },
          "command": {
            "type": "string",
            "description": "Command that was executed",
            "example": "configure add"
          },
          "parameters": {
            "type": "string",
            "description": "Parameters used in the command",
            "example": "configure add"
          },
          "status": {
            "type": "string",
            "description": "Status of the command",
            "example": "Failed, Succeeded"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "username": {
            "type": "string",
            "description": "Name of the user who executed the command"
          },
          "logs": {
            "type": "string",
            "description": "Full logs of the command"
          }
        },
        "example": {
          "start_time": "2000-01-23T04:56:07.000+00:00",
          "end_time": "2000-01-23T04:56:07.000+00:00",
          "id": "id",
          "parameters": "configure add",
          "logs": "logs",
          "command": "configure add",
          "status": "Failed, Succeeded"
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "role-name": {
            "type": "string",
            "description": "Name of the role",
            "example": "SecurityAdmin"
          },
          "description": {
            "type": "string",
            "description": "Short Description of the role",
            "example": "Performs user management, PKI and key management operations in the system"
          }
        }
      },
      "RoleList": {
        "type": "object",
        "properties": {
          "role-list": {
            "title": "Full list of roles",
            "type": "array",
            "description": "List of roles or specific role details",
            "example": "{role-list:[{role-name:FabricAdmin,description:Registers devices to fabric...},{role-name:SecurityAdmin,description:Performs user management, PKI and key management operations in the system.}...}]}",
            "items": {
              "$ref": "#/components/schemas/Role"
            }
          }
        }
      },
      "AuthorizedTenants": {
        "type": "object",
        "properties": {
          "accessible": {
            "type": "string",
            "description": "Holds 'all' for static roles and 'specific' for dynamic roles."
          },
          "tenants": {
            "title": "list of tenants",
            "type": "array",
            "description": "List of tenants when accessible property has the value 'specific'. The list is empty when the accessible property has the value 'all'.",
            "items": {
              "type": "string"
            }
          }
        },
        "example": "{accessible: specific, tenants:[{tenant-one, tenant-two}]}"
      },
      "ErrorModel": {
        "required": [
          "code",
          "message"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "1000 - No Error.\n1001 - Validation Error.\n30001 - Casbin enforcer Error.\n30002 - Policy definition loading Error.\n30003 - Role does not exists Error.\n30004 - No permissions for role Error.\n30005 - No role found Error.\n30006 - No method found Error.\n30007 - No path found Error\n"
          },
          "message": {
            "type": "string",
            "description": "Describing the reason of failure"
          }
        },
        "example": {
          "code": 0,
          "message": "message"
        }
      },
      "UserPermissionList": {
        "type": "object",
        "properties": {
          "roles": {
            "type": "array",
            "description": "User roles",
            "items": {
              "type": "string"
            },
            "example": [
              "SecurityAdmin"
            ]
          },
          "deployment-type": {
            "type": "string",
            "description": "Type of the deployment",
            "enum": [
              "fabric",
              "packet",
              "all"
            ],
            "example": "fabric"
          },
          "skip-check": {
            "type": "string",
            "description": "Skip the permission check for special cases"
          },
          "permission-list": {
            "title": "List of permissions",
            "type": "string",
            "description": "permission string"
          }
        }
      }
    }
  }
}