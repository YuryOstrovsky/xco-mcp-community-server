{
  "openapi": "3.0.3",
  "info": {
    "title": "SNMP Service",
    "description": "This is the spec that defines the API provided by the SNMP Service.",
    "version": "3.8.0",
    "contact": {
      "name": "Extreme Networks",
      "url": "http://www.extremenetworks.com",
      "email": "support@extremenetworks.com"
    },
    "license": {
      "name": "Apache license",
      "url": "http://www.extremenetworks.com"
    }
  },
  "servers": [
    {
      "url": "http://gosnmp-service:80/v1/snmp"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/subscribers": {
      "get": {
        "summary": "getTrapSubscribers",
        "description": "Get all the trap subscribers from the SNMP service.",
        "operationId": "GetTrapSubscribers",
        "tags": [
          "Subscriber"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TrapSubscriber"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "registerTrapSubscriber",
        "description": "Register trap subscriber with the SNMP service.",
        "operationId": "RegisterTrapSubscriber",
        "tags": [
          "Register"
        ],
        "requestBody": {
          "description": "Register a new trap subscriber for SNMP messages.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrapSubscriber"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrapSubscriber"
                }
              }
            }
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/subscriber/{host}": {
      "delete": {
        "summary": "deleteTrapSubscriber",
        "description": "Delete the specified trap subscriber from the SNMP service.",
        "operationId": "DeleteTrapSubscriber",
        "tags": [
          "Subscriber"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "host",
            "description": "Specify the hostname or IPv4/IPv6 address of the trap subscriber entry to be deleted.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "404": {
            "description": "A subscriber with the given subscriber host was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/execution": {
      "get": {
        "tags": [
          "Trouble Shooting"
        ],
        "summary": "getExecutionDetail",
        "description": "Get the detailed output of a request previously executed, based on a given request ID.",
        "operationId": "ExecutionGet",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "Detailed output of a request previously executed, based on a given request ID.",
            "required": true,
            "schema": {
              "type": "string",
              "x-exportParamName": "Id"
            },
            "x-exportParamName": "Id"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetailedExecutionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/executions": {
      "get": {
        "tags": [
          "Trouble Shooting"
        ],
        "summary": "getExecutionList",
        "description": "Get the list of all the requests previously executed.",
        "operationId": "ExecutionList",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Limit the number of executions that will be sent in the response. Default is 10",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 10,
              "x-exportParamName": "Limit"
            },
            "x-exportParamName": "Limit"
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter the executions based on the status (failed/succeeded/all).",
            "schema": {
              "type": "string",
              "default": "all",
              "x-exportParamName": "Status"
            },
            "x-exportParamName": "Status"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authorization information is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "getHealth",
        "description": "Get the health of the RASlog service.",
        "operationId": "GetHealth",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "TrapSubscriber": {
        "type": "object",
        "required": [
          "id",
          "type",
          "host"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "v2community": {
            "type": "string"
          },
          "v3user": {
            "type": "string"
          },
          "v3authprotocol": {
            "type": "string"
          },
          "v3authpassword": {
            "type": "string"
          },
          "v3privprotocol": {
            "type": "string"
          },
          "v3privpassword": {
            "type": "string"
          }
        }
      },
      "ErrorModel": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "example": "Subscriber is not found."
          },
          "code": {
            "type": "integer",
            "minimum": 100,
            "maximum": 600,
            "example": 101
          }
        }
      },
      "HealthStatus": {
        "type": "object",
        "required": [
          "Service"
        ],
        "properties": {
          "Service": {
            "type": "string"
          }
        }
      },
      "ExecutionsResponse": {
        "title": "Fabrics Data",
        "type": "object",
        "properties": {
          "items": {
            "uniqueItems": true,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExecutionResponse"
            }
          }
        },
        "example": {
          "items": [
            {
              "start_time": "2000-01-23T04:56:07.000+00:00",
              "end_time": "2000-01-23T04:56:07.000+00:00",
              "id": "id",
              "command": "subscriber add",
              "status": "Successful"
            },
            {
              "start_time": "2000-01-23T04:56:07.000+00:00",
              "end_time": "2000-01-23T04:56:07.000+00:00",
              "id": "id",
              "command": "subscriber add",
              "status": "Successful"
            }
          ]
        }
      },
      "ExecutionResponse": {
        "title": "Single execution response",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the operation."
          },
          "command": {
            "type": "string",
            "description": "Command that was executed.",
            "example": "subscriber add"
          },
          "parameters": {
            "type": "string",
            "description": "Parameters that were sent for the command.",
            "example": "host:1.1.1.1"
          },
          "status": {
            "type": "string",
            "description": "Command that was executed.",
            "example": "Successful"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "user_name": {
            "type": "string",
            "description": "Name of the user who executed the command."
          }
        },
        "example": {
          "start_time": "2000-01-23T04:56:07.000+00:00",
          "end_time": "2000-01-23T04:56:07.000+00:00",
          "id": "id",
          "command": "subscriber add",
          "status": "Completed",
          "user_name": "admin"
        }
      },
      "DetailedExecutionResponse": {
        "title": "Detailed output of single execution",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the operation."
          },
          "command": {
            "type": "string",
            "description": "Command that was executed.",
            "example": "subscriber add"
          },
          "parameters": {
            "type": "string",
            "description": "Parameters used in the command.",
            "example": "host=10.0.0.2"
          },
          "status": {
            "type": "string",
            "description": "Status of the command.",
            "example": "Failed, Succeeded"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "user_name": {
            "type": "string",
            "description": "Name of the user who executed the command."
          },
          "logs": {
            "type": "string",
            "description": "Full logs of the command."
          }
        },
        "example": {
          "start_time": "2000-01-23T04:56:07.000+00:00",
          "end_time": "2000-01-23T04:56:07.000+00:00",
          "id": "id",
          "parameters": "host=10.0.0.2",
          "logs": "logs",
          "command": "subscriber add",
          "status": "Failed, Succeeded"
        }
      }
    }
  }
}