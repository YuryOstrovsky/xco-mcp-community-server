    "category": "system",
    "method": "GET",
    "endpoint": {
      "host": "{XCO_HOST}",
      "path": "/v1/system/proxy/supportsavestatus"
    },
    "auth": "bearer",
    "input_schema": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Request ID returned when a SupportSave operation is initiated"
        }
      },
      "required": ["id"]
    },
    "policy": {
      "risk": "SAFE_READ",
      "allowed_in_auto_mode": false,
      "requires_confirmation": false,
      "notes": "Requires a request ID generated by the SupportSave creation API. Cannot be used with filenames returned by supportsave list."
    },
    "usage": {
      "requires_prior_action": "system_create_supportsave",
      "notes": "The request ID is only available from the SupportSave creation response. Completed supportsave files do not expose execution IDs."
    },
    "tags": ["read", "system", "supportsave", "execution", "tier3"],
    "capabilities": {
      "actions": ["show"],
      "objects": ["supportsave", "execution"],
      "scopes": [["system"]]
    }
