      "read",
      "fabric",
      "topology",
      "physical",
      "tier1"
    ],
    "capabilities": {
      "actions": ["list"],
      "objects": ["link", "device"],
      "scopes": [["fabric"]],
      "fabric_param": "fabric-name"
    }
  }
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  

  
  
  
  
  
  
  
