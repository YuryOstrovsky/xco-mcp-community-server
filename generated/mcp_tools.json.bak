  {
    "name": "fabric_get_devices_by_fabric_name",
    "description": "Get all devices in a fabric by fabric name (explicit fabric-name required)",
    "category": "fabric",
    "method": "GET",
    "endpoint": {
      "path": "/v1/fabric/devices"
    },
    "auth": "none",
    "input_schema": {
      "type": "object",
      "properties": {
        "fabric-name": {
          "type": "string",
          "description": "Fabric name (required, e.g. DC)"
        }
      },
      "required": ["fabric-name"]
    },
    "policy": {
      "risk": "SAFE_READ",
      "allowed_in_auto_mode": true,
      "requires_confirmation": false
    },
    "tags": ["read", "fabric", "devices", "tier1"],
    "capabilities": {
      "actions": ["list"],
      "objects": ["device"],
      "scopes": [["fabric"]]
    }
  },
  {
    "name": "fabric_get_physical_topology",
