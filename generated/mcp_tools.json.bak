[
  {
    "name": "inventory_getswitches",
    "description": "Get switches",
    "category": "inventory",
    "method": "GET",
    "endpoint": {
      "host": "{XCO_HOST}",
      
      "path": "/v1/inventory/switches"
    },
    "auth": "none",
    "input_schema": {
      "type": "object",
      "properties": {
        "fabric-id": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "required": []
    },
    "policy": {
      "risk": "SAFE_READ",
      "allowed_in_auto_mode": true,
      "requires_confirmation": false
    },
    "tags": [
      "read"
    ],
    "capabilities": {
      "actions": [
        "show"
      ],
      "objects": [
        "switches"
      ],
      "scopes": [
        [
          "fabric"
        ],
        [
          "device"
        ]
      ]
    }
  },
